# Copy this file to .env and fill in your key
# NEVER commit .env to version control

# Google Gemini API Key (required)
# Get it free at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps Embed API Key (optional — enhances maps, falls back to OpenStreetMap)
# Enable "Maps Embed API" in your Google Cloud project
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here
